{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
          "extraArgs": [
            "--",
            "-Dclippy::unwrap_used",
            "-Dclippy::expect_used",
            "-Dclippy::panic",
          ],
          "checkOnSave": true,
        },
      },
    },
  },
}
