{
    "extends": "./.svelte-kit/tsconfig.json",
    "compilerOptions": {
        "rewriteRelativeImportExtensions": true,
        "allowJs": true,
        "checkJs": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": false,
        "strict": true,
        "moduleResolution": "bundler",
        "types": [""],
    },
    "build": {
        "rollupOptions": {
            "output": {
                "minify": {
                    "compress": {
                        "drop_console": true,
                        "drop_debugger": true,
                    },
                },
            },
        },
    },
}
